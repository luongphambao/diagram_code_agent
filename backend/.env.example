# --- Required ---
# OpenAI API key used by the diagram agent and the planner.
OPENAI_API_KEY=sk-...

# --- Sessions (Postgres) ---
# Durable session storage (LangGraph checkpointer + store). When set, threads
# survive a server restart. Leave UNSET for in-memory dev (lost on restart).
# docker compose sets this automatically to the bundled postgres service.
# DATABASE_URL=postgresql://diagram:diagram@localhost:5432/diagram

# --- Composio (email + calendar + meet integrations) ---
# Required only if using send_email or create_client_meeting tools.
# Get your API key at https://app.composio.dev → API Keys
COMPOSIO_API_KEY=
# Run `cd backend && uv run python setup_gmail_composio.py` after connecting
# Gmail in Composio, then copy the ACTIVE connected account ID here.
GMAIL_CONNECTED_ACCOUNT_ID=
GOOGLE_CALENDAR_CONNECTED_ACCOUNT_ID=
# Required only if using the read-only Google Meet tools (list_meeting_records,
# get_meeting_transcript, get_meeting_recordings, list_meeting_participants).
# Run `composio add googlemeet`, then copy the ACTIVE connected account ID here
# (same lookup pattern as setup_gmail_composio.py, filtering on toolkit "googlemeet").
GOOGLE_MEET_CONNECTED_ACCOUNT_ID=

# --- Qdrant (RAG / vector search) ---
# Cloud: get URL and API key from https://cloud.qdrant.io
# Self-hosted: QDRANT_URL=http://localhost:6333 (no API key needed)
# QDRANT_URL=https://<cluster-id>.aws.cloud.qdrant.io
# QDRANT_API_KEY=<your-token>
# Run once to build the index after setting these:
#   cd backend && PYTHONPATH=src python -m diagram_mcp.rag.indexer

# --- Optional ---
# Port the AG-UI server listens on (frontend defaults to 8001).
# DIAGRAM_AGENT_PORT=8001

# Deployment environment. Controls fail-closed behavior for CORS (§0.5) and auth
# (§0.6) — set to "production" for any real (non-laptop) deployment.
# APP_ENV=development

# Comma-separated CORS origins allowed to call the API. Required (server refuses
# to start) when APP_ENV=production; non-production falls back to a small
# local-dev allowlist (localhost:5173) rather than "*".
# ALLOWED_ORIGINS=http://localhost:5173

# --- Authentication (improvement plan §0.6) ---
# Internal/trusted-org auth — not full multi-tenant SaaS (no login flow, no user
# database). Pick ONE mode via AUTH_MODE; APP_ENV=production refuses to start
# with anything other than "header" or "bearer" (a client-supplied identity
# cannot gate HITL approval or thread ownership in production).
#   header — trust identity headers set by a reverse proxy/SSO gateway in front
#            of this service (oauth2-proxy, Authelia, Cloudflare Access, nginx
#            auth_request, ...). The gateway authenticates the caller and
#            forwards AUTH_HEADER_EMAIL / AUTH_HEADER_ROLE.
#   bearer — trust a small static set of tokens issued out-of-band, no reverse
#            proxy needed. AUTH_BEARER_TOKENS="token:email:role,token2:email2:role2".
#            role is one of ROLE_GATE_PERMISSIONS in tools/__init__.py
#            (architect, pm, lead, admin, ...) or blank (permissive).
#   none   — DEV ONLY (the default here). Falls back to trusting the frontend's
#            client-supplied userEmail/userRole. Refused when APP_ENV=production.
# AUTH_MODE=header
# AUTH_HEADER_EMAIL=X-Auth-Request-Email
# AUTH_HEADER_ROLE=X-Auth-Request-Role
# AUTH_BEARER_TOKENS=

# --- Modal Sandbox (generated diagram-code execution — improvement plan §0.1) ---
# Get credentials at https://modal.com → Settings → API Tokens, or `modal token new`.
# Required when SANDBOX_PROVIDER=modal (the default; see runtime/sandbox/provider.py).
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...
# "modal" (default, isolated) or "local" (same-interpreter subprocess — only
# permitted when APP_ENV != production).
# SANDBOX_PROVIDER=modal

# Mount per-session workspaces somewhere outside agent_space/ (host-visible).
# In docker-compose this is set to /app/artifacts and bind-mounted to ./artifacts,
# so each session shows up as ./artifacts/<threadId>/. Leave unset for the default
# (backend/agent_space/workspaces/<threadId>).
# ARTIFACTS_DIR=/absolute/path/to/artifacts

# Only needed if you switch the generation model to a Claude model.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Jira delivery export (optional) ---
# Required only if you run export_to_delivery(system="jira", dry_run=false) and want a
# REAL push. Leave unset to keep the deterministic offline simulation (CI-safe). Auth is
# Jira Cloud REST v3 Basic auth (email + API token).
# JIRA_BASE_URL=https://acme.atlassian.net
# JIRA_EMAIL=you@acme.com
# JIRA_API_TOKEN=<token from id.atlassian.com/manage-profile/security/api-tokens>
# JIRA_PROJECT_KEY=PROJ
# Optional: the custom field id for effort (e.g. customfield_10016). If unset, the effort
# estimate is folded into the issue description instead of posted as a custom field.
# JIRA_EFFORT_FIELD=customfield_10016

# --- Optional Draw.io MCP refiner ---
# Enables an optional post-export .drawio refinement path using:
#   npx @next-ai-drawio/mcp-server@latest
# Requires Node.js/npm/npx on the host. Leave disabled for the normal pipeline.
# DRAWIO_MCP_ENABLED=false
# DRAWIO_MCP_COMMAND=npx.cmd      # Windows; use npx on Linux/macOS
# DRAWIO_MCP_ARGS=--yes @next-ai-drawio/mcp-server@latest
# DRAWIO_MCP_PORT=6002
# DRAWIO_MCP_DRAWIO_BASE_URL=https://embed.diagrams.net

# --- LangSmith tracing (optional) ---
# Set TRACING=true and provide an API key to send traces to LangSmith.
# Get a key at https://smith.langchain.com (Settings → API Keys).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=diagram-code-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com   # EU: https://eu.api.smith.langchain.com
