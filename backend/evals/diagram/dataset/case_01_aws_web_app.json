  "expected_nodes": [
    "CloudFront", "ALB", "ECS", "RDS", "ElastiCache", "S3",
    "Route53", "Cognito", "CloudWatch"
  ],
  "expected_edges": [
    {"from": "User", "to": "CloudFront"},
    {"from": "CloudFront", "to": "ALB"},
    {"from": "ALB", "to": "ECS"},
    {"from": "ECS", "to": "RDS"},
    {"from": "ECS", "to": "ElastiCache"},
    {"from": "ECS", "to": "S3"}
  ],
  "expected_clusters": [
    "Client", "Edge", "Application", "Data"
  ],
  "min_nodes": 6,
  "min_edges": 4,
  "min_clusters": 3
